class Time:
    def __init__(self, h, m, s):
        self.h = h
        self.m = m
        self.s = s
    def __add__(self, other):
        total_sec = self.s + other.s
        total_min = self.m + other.m
        total_hr = self.h + other.h
        if total_sec >= 60:
            total_sec -= 60
            total_min += 1

        if total_min >= 60:
            total_min -= 60
            total_hr += 1

        return Time(total_hr, total_min, total_sec)

    def display(self):
        print(f"{self.h:02}:{self.m:02}:{self.s:02}")

# Creating two time objects
t1 = Time(5, 40, 35)
t2 = Time(4, 30, 45)

# Add times
t3 = t1 + t2  # t1.__add__(t2)

# Display result
t3.display()  # 10:11:20






